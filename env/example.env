# URL pública del sitio (usada para emails y metadatos)
NEXT_PUBLIC_SITE_URL=https://www.tresmorroscoliumo.cl
PUBLIC_EXTERNAL_URL=https://www.tresmorroscoliumo.cl

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloca-tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=coloca-tu-service-role-key

# Flow Payment Gateway - PRODUCCIÓN
# ⚠️ IMPORTANTE: Configurar estas claves en DigitalOcean App Platform
# Webhook URL a configurar en Flow Dashboard: https://www.tresmorroscoliumo.cl/api/payments/flow/webhook
FLOW_API_KEY=7DAA6E3F-1804-4FBD-999C-805C6988LCB6
FLOW_SECRET_KEY=76930528c3ce6accbc89187dc50960f932ee864c
FLOW_BASE_URL=https://www.flow.cl/api
FLOW_FORCE_MOCK=false
FLOW_ALLOW_MOCK_IN_PROD=false
FLOW_ALLOW_SANDBOX_IN_PROD=false
FLOW_HTTP_TIMEOUT_MS=15000
FLOW_DEBUG_LOGS=false

# Observabilidad (Sentry)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# Configuración de huéspedes (sincronizada con packages/core/src/lib/config/booking.ts)
NEXT_PUBLIC_DEFAULT_INCLUDED_GUESTS=2
NEXT_PUBLIC_MAX_EXTRA_GUESTS=5

# Email (SendGrid)
SENDGRID_API_KEY=tu-sendgrid-api-key
SENDGRID_FROM_EMAIL=reservas@tresmorroscoliumo.cl
SENDGRID_FROM_NAME=Tres Morros de Coliumo

# Panel admin
ADMIN_PASSWORD=cambia-esto
ADMIN_SESSION_SECRET=super-session-secret

# Jobs / cron
CRON_SECRET=define-una-clave

# Opcional: desactiva telemetría de Next
NEXT_TELEMETRY_DISABLED=1
